{
  "name": "inistate-mcp",
  "version": "1.0.0",
  "description": "MCP server for the Inistate platform — module discovery, entry management, and activity submission",
  "type": "module",
  "author": "Inistate",
  "homepage": "https://github.com/Inistate/inistate-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Inistate/inistate-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Inistate/inistate-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "inistate",
    "workflow",
    "low-code",
    "ai-agent",
    "claude"
  ],
  "bin": {
    "inistate-mcp": "./build/index.js",
    "inistate-mcp-http": "./build/http.js"
  },
  "files": [
    "build/**/*.js"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "start:http": "node build/http.js",
    "inspector": "npx @modelcontextprotocol/inspector build/index.js",
    "pm2:start": "pm2 start ecosystem.config.cjs --env production",
    "pm2:restart": "pm2 restart inistate-mcp",
    "pm2:stop": "pm2 stop inistate-mcp",
    "pm2:logs": "pm2 logs inistate-mcp"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/iarna__toml": "^2.0.5",
    "@types/node": "^22.0.0",
    "pm2": "^7.0.1",
    "typescript": "^5.8.0",
    "vitest": "^3.2.4"
  },
  "license": "Apache-2.0"
}
