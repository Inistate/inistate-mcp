# Inistate MCP Server Configuration

# Bearer token for Inistate API authentication (required)
INISTATE_API_TOKEN=your-api-token-here

# API base URL (optional, defaults to https://app02.apps.inistate.com)
INISTATE_API_URL=https://app02.apps.inistate.com

# Default workspace ID (recommended for stateless/remote deployments)
# Without this, clients must call set_workspace on every request.
INISTATE_WORKSPACE_ID=

# Public URL of this server (required for OAuth 2.0 metadata)
# Must match the URL clients use to reach this server.
OAUTH_ISSUER_URL=https://mcp.inistate.com

# Frontend app URL (login page is hosted here)
INISTATE_APP_URL=https://app.inistate.com

# Path to the login page on the frontend app (optional, defaults to "/#/login")
# Examples: "/#/login" (Vue hash routing), "/login", "/oauth/authorize"
INISTATE_APP_LOGIN_PATH=/#/login

OPENAI_VERIFICATION_TOKEN=ABCDEFGHIJKLMNOPQRSTUVWxyz1234123
